# ForgeOS environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — NEVER commit real credentials.

# ── Supabase (used from Phase 0) ─────────────────────────────────────────────

# Project URL — Supabase dashboard → Project Settings → API → Project URL.
# Browser-safe (NEXT_PUBLIC prefix).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public API key — Supabase dashboard → Project Settings → API Keys.
# The legacy "anon" key or a new-style publishable key (sb_publishable_...)
# both work. Browser-safe: row access is enforced by RLS, not by this key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Service-role key — Supabase dashboard → Project Settings → API Keys
# ("service_role", or a new-style secret key sb_secret_...).
# SERVER-ONLY — bypasses Row Level Security. Never expose to the browser and
# never give it a NEXT_PUBLIC prefix. Only src/lib/supabase/admin.ts reads it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database password — set when the Supabase project was created (resettable in
# dashboard → Project Settings → Database). SERVER/CLI-ONLY: used by the
# Supabase CLI for direct-connection tasks like running migrations (Phase 1+).
SUPABASE_DATABASE_PASSWORD=your-database-password

# Personal access token — https://supabase.com/dashboard/account/tokens.
# SERVER/CLI-ONLY: lets the Supabase CLI link this repo to the cloud project
# (supabase link / db push) without an interactive login. Never browser-exposed.
SUPABASE_ACCESS_TOKEN=your-access-token

# ── Anthropic (reserved — no AI code until Phase 3) ──────────────────────────

# SERVER-ONLY API key from https://console.anthropic.com. Unused in Phase 0.
ANTHROPIC_API_KEY=your-anthropic-api-key

# Claude model id for AI features (configurable per environment, e.g.
# claude-sonnet-5). Unused in Phase 0.
ANTHROPIC_MODEL=claude-sonnet-5
